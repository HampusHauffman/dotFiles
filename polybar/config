[bar/example]
;monitor = ${env:MONITOR:HDMI-1}

width = 100%
height = 55
;offset-x = 1%
;offset-y = 1%
radius = 0.0
fixed-center = false
bottom = true
background = ${colors.background}
foreground = ${colors.foreground}

line-size = 4
line-color = ${colors.col0}

border-top-size = 8
border-color = ${colors.primary}
 

module-margin-left = 0
module-margin-right = 0

font-0 = Hack Nerd Font:style=Regular:size=24;5

modules-left =i3 
;modules-right = filesystem xbacklight alsa pulseaudio xkeyboard memory cpu wlan eth battery temperature date powermenu
;modules-center = spotify
modules-right = pulseaudio wlan battery date 

tray-position = right
tray-padding = 3
tray-background = ${colors.primary}

;wm-restack = bspwm
;wm-restack = i3

scroll-up = i3wm-wsnext
scroll-down = i3wm-wsprev

cursor-click = pointer
cursor-scroll = ns-resize

[module/play-pause]
type = custom/text
content = PLAY
click-middle = playerctl play-pause &

[module/spotify]
type = custom/script
interval = 1
format-prefix = "ΎΑΒ "
format = <label>
;exec = python /usr/share/polybar/scripts/spotify_status.py -f '{artist}: {song}'
exec = python /usr/share/polybar/scripts/spotify_status.py  -f '{artist}: {song}' -t 15

format-underline = ${colors.primary}
;click-left = playerctl play-pause &
;click-right = playerctl next &


[module/filesystem]
type = internal/fs
interval = 25

mount-0 = /
label-mounted = %{F${colors.primary}%mountpoint%%{F-}: %percentage_used%%
label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.foreground-alt}

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
index-sort = true
wrapping-scroll = false

; Only show workspaces on the same output as the bar
;pin-workspaces = true

label-mode-padding = 2
label-mode-foreground = #000
label-mode-background = ${colors.primary}

; focused = Active workspace on focused monitor
;label-focused = %index%
label-focused = %name%
label-focused-background = ${colors.primary}
;label-focused-background = ${colors.background-alt}
label-focused-underline= ${colors.primary}
label-focused-padding = 2

; unfocused = Inactive workspace on any monitor
label-unfocused = %name%
label-unfocused-padding = 2

; visible = Active workspace on unfocused monitor
label-visible = %name%
label-visible-background = ${self.label-focused-background}
label-visible-underline = ${self.label-focused-underline}
label-visible-padding = ${self.label-focused-padding}

; urgent = Workspace with urgency hint set
label-urgent = %name%
label-urgent-background = ${colors.alert}
label-urgent-padding = 2

; Separator in between workspaces
; label-separator = |
strip-wsnumbers = true

[module/mpd[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "ΎΜδ"
format-prefix-foreground = ${colors.foreground-alt}
format-underline = #f90000
label = %percentage:2%%

[module/memory]
type = internal/memory
interval = 2
format-prefix = "ΎαΜ "
format-prefix-foreground = ${colors.foreground-alt}
;format-underline = #4bffdc
label = %percentage_used%%

[module/wlan]
type = internal/network
interface = wlp2s0
interval = 3.0

format-connected-background = ${colors.col3}
format-connected-padding = 2

format-connected = <ramp-signal> <label-connected>
;format-connected-underline = #9f78e1
label-connected = %essid%


format-disconnected =
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}

ramp-signal-0 ="Ύλι "
ramp-signal-1 ="Ύλμ "
ramp-signal-2 ="Ύλο "
ramp-signal-3 ="Ύλσ "
ramp-signal-4 ="Ύλυ "
ramp-signal-foreground = ${colors.foreground-alt}

[module/eth]
type = internal/network
interface = net0
interval = 3.0

format-connected-underline = #55aa55
format-connected-prefix = "ΌΗε "
format-connected-prefix-foreground = ${colors.foreground-alt}
label-connected = %local_ip%

format-disconnected = Ύκ╡
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}

[module/date]
type = internal/date
interval = 5

date =
date-alt = " %Y-%m-%d"

time = %H:%M
time-alt = %H:%M:%S
;ΌΟΒΌΟΓΌΟΔΌΟΕΌΟΖΌΟΗΌΟΘ
format-prefix ="ΌΟΓ "   
format-prefix-foreground = ${colors.foreground-alt}
format-background = ${colors.col1}
;format-underline = #0a6cf5
format-padding = 2
label = %date% %time%

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <label-volume> <bar-volume>
label-volume = %percentage%%
label-volume-foreground = ${root.foreground}

label-muted ="ΎςΑ "
label-muted-foreground = ${root.foreground}

bar-volume-width = 7
bar-volume-foreground-0 = ${colors.col1}
bar-volume-foreground-1 = ${colors.col2}
bar-volume-foreground-2 = ${colors.col3}
bar-volume-foreground-3 = ${colors.col4}
bar-volume-foreground-4 = ${colors.col5}
bar-volume-foreground-5 = ${colors.col6}
bar-volume-foreground-6 = ${colors.col7}
bar-volume-gradient = false
bar-volume-indicator = |
bar-volume-indicator-font = 2
bar-volume-fill = έΦΑ
bar-volume-fill-font = 2
bar-volume-empty = έΦΑ
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground-alt}

format-muted-background = ${colors.col1}
format-muted-padding = 2

format-volume-background = ${colors.col1}
format-volume-padding = 2

[module/alsa]
type = internal/alsa

format-volume = <label-volume> <bar-volume>
label-volume = VOL
label-volume-foreground = ${root.foreground}

format-muted-prefix = "ΌΙΓ "
format-muted-foreground = ${colors.foreground-alt}
label-muted = sound muted

bar-volume-width = 10
bar-volume-foreground-0 = #55aa55
bar-volume-foreground-1 = #55aa55
bar-volume-foreground-2 = #55aa55
bar-volume-foreground-3 = #55aa55
bar-volume-foreground-4 = #55aa55
bar-volume-foreground-5 = #f5a70a
bar-volume-foreground-6 = #ff5555
bar-volume-gradient = false
bar-volume-indicator = |
bar-volume-indicator-font = 2
bar-volume-fill = έΦΑ
bar-volume-fill-font = 2
bar-volume-empty = έΦΑ
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground-alt}

[module/battery]
type = internal/battery
battery = BAT0
adapter = AC0
full-at = 98


format-discharging-padding = 2
format-full-padding = 2
format-charging-padding = 2
format-charging-background = ${colors.col2}
format-full-background = ${colors.col2}
format-discharging-background = ${colors.col2}

format-charging = <animation-charging> <label-charging>
;format-charging-underline = #ffb52a

format-discharging = <animation-discharging> <label-discharging>
;format-discharging-underline = ${self.format-charging-underline}

format-full-prefix = "ΎΚΑ "
format-full-prefix-foreground = ${colors.foreground-alt}
;format-full-underline = ${self.format-charging-underline}

ramp-capacity-0 = ΎΚΕ
ramp-capacity-1 = ΎΚΔ
ramp-capacity-2 = ΎΚΓ
ramp-capacity-3 = ΎΚΒ
ramp-capacity-4 = ΎΚΑ
ramp-capacity-foreground = ${colors.foreground-alt}

animation-charging-0 = ΎΨΖ 
animation-charging-1 = ΎΨΘ
animation-charging-2 = ΎΨΛ
animation-charging-foreground = ${colors.foreground-alt}
animation-charging-framerate = 750
#
animation-discharging-0 = Ύ┤Ζ
animation-discharging-1 = Ύ┤Ξ
animation-discharging-2 = Ύ┤Ν
animation-discharging-3 = Ύ┤Μ
animation-discharging-4 = Ύ┤Λ
animation-discharging-5 = Ύ┤Ι
animation-discharging-6 = Ύ┤Θ
animation-discharging-7 = Ύ┤Η
animation-discharging-8 = Ύ┤Ρ
animation-discharging-foreground = ${colors.foreground-alt}
animation-discharging-framerate = 750

[module/temperature]
type = internal/temperature
thermal-zone = 0
warn-temperature = 60

format = <ramp> <label>
;format-underline = #f50a4d
format-warn = <ramp> <label-warn>
;format-warn-underline = ${self.format-underline}

label = %temperature-c%
label-warn = %temperature-c%
label-warn-foreground = ${colors.secondary}

ramp-0 = ΎΜΜ
ramp-1 = ΎΜΚ
ramp-2 = ΎΜΘ
ramp-foreground = ${colors.foreground-alt}

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
;pseudo-transparency = false

[global/wm]
margin-top = 5
margin-bottom = 5

; vim:ft=dosini
